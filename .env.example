# Copy this file to .env and fill in your values
# Frontend (Vite — prefix with VITE_ to expose to browser)
VITE_PB_URL=https://your-pocketbase.railway.app

# Backend (PocketBase environment variables — set in Railway/Render dashboard)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_TIER1=price_...
STRIPE_PRICE_TIER2=price_...
STRIPE_PRICE_TIER3=price_...
STRIPE_PRICE_TIER4=price_...
STRIPE_PRICE_TIER5=price_...
